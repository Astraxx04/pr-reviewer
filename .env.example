# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8001
APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL with pgvector is required. Schema is applied automatically on startup.
# Local Docker:
#   docker run -d -p 5432:5432 \
#     -e POSTGRES_USER=pr_reviewer -e POSTGRES_PASSWORD=pr_reviewer \
#     -e POSTGRES_DB=pr_reviewer pgvector/pgvector:pg16
DATABASE_URL=postgres://pr_reviewer:pr_reviewer@localhost:5432/pr_reviewer?sslmode=disable

# ── Security ──────────────────────────────────────────────────────────────────
# Both values must be 64-char hex strings (32 bytes each).
# Generate with: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Required for user login. Create at: github.com/settings/developers → OAuth Apps
#   Homepage URL:           set to your FRONTEND_URL value
#   Authorization callback: http://localhost:8001/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── URLs ──────────────────────────────────────────────────────────────────────
# Keep all browser-facing URLs on localhost: OAuth must start and finish on the
# same host (so the oauth_state cookie round-trips), and the SSE EventSource is
# blocked by ngrok's free-tier browser warning. ngrok is for webhooks only.
SERVER_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8001

# ── ngrok (inbound GitHub webhooks only) ──────────────────────────────────────
# The dev stack (docker-compose.dev.yml) runs an ngrok service that exposes a
# stable public URL for GitHub webhook delivery. Set the GitHub App's webhook URL
# to https://${NGROK_DOMAIN}/<webhook path> once.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=your-reserved-domain.ngrok-free.dev

# ── Optional: access control ──────────────────────────────────────────────────
# Restrict logins to members of a specific GitHub organisation.
# REQUIRED_GITHUB_ORG=your-org

# Require admin approval before new users can access the app.
# INVITE_ONLY=false

# JWT lifetime in hours (default: 24).
# JWT_TTL_HOURS=24

# ── Optional: observability (OpenTelemetry tracing) ───────────────────────────
# Unset = tracing disabled (no-op, zero overhead).
# "stdout" = pretty-print spans to the server's terminal.
# Any other value = OTLP/HTTP collector endpoint, e.g. http://localhost:4318 (Jaeger/Tempo).
# OTEL_EXPORTER_OTLP_ENDPOINT=stdout

# ─────────────────────────────────────────────────────────────────────────────
# Everything else is configured through the Settings UI after first login and
# stored (encrypted) in the database — no env vars needed:
#   • GitHub App (App ID + private key) and the GitHub token used to post reviews
#   • Webhook secret for verifying incoming GitHub webhooks
#   • AI providers, notifications (Slack/email), Jira, SSO
# ─────────────────────────────────────────────────────────────────────────────
