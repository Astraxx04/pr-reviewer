# Runtime image used by GoReleaser. Unlike ./Dockerfile (which builds from
# source), this consumes the binary GoReleaser already cross-compiled and places
# in the build context — GoReleaser's Docker context contains only the built
# artifacts, not the Go source, so there is no go.mod/go.sum to compile from here.
FROM alpine:latest

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app
COPY pr-reviewer /app/pr-reviewer

EXPOSE 8001
ENTRYPOINT ["/app/pr-reviewer"]
